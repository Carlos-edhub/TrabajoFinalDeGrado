<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.MiAplicacion" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Premium colours with higher contrast for elderly -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">#E8F0FE</item>
        <item name="colorOnPrimaryContainer">@color/primary_dark</item>

        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnSecondary">@color/on_secondary</item>

        <item name="android:colorBackground">@color/background</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/on_surface</item>
        <item name="colorOnSurfaceVariant">@color/on_surface_variant</item>

        <item name="colorError">@color/error</item>
        <item name="colorOnError">@color/on_error</item>

        <!-- Typography (increased sizes for readability) -->
        <item name="textAppearanceHeadlineLarge">@style/TextAppearance.HeadlineLarge</item>
        <item name="textAppearanceHeadlineMedium">@style/TextAppearance.HeadlineMedium</item>
        <item name="textAppearanceTitleMedium">@style/TextAppearance.TitleMedium</item>
        <item name="textAppearanceBodyLarge">@style/TextAppearance.BodyLarge</item>
        <item name="textAppearanceBodyMedium">@style/TextAppearance.BodyMedium</item>
        <item name="textAppearanceLabelLarge">@style/TextAppearance.LabelLarge</item>

    </style>

    <style name="Theme.MiAplicacion" parent="Base.Theme.MiAplicacion" />

    <!-- Activity animations -->
    <style name="Theme.MiAplicacion.Anim" parent="Theme.MiAplicacion">
        <item name="android:activityOpenEnterAnimation">@anim/slide_in_right</item>
        <item name="android:activityOpenExitAnimation">@anim/slide_out_left</item>
        <item name="android:activityCloseEnterAnimation">@anim/slide_in_left</item>
        <item name="android:activityCloseExitAnimation">@anim/slide_out_right</item>
    </style>

    <!-- Splash Screen -->
    <style name="Theme.MiAplicacion.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/primary</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.MiAplicacion</item>
    </style>

    <!-- Premium Card (bigger padding) -->
    <style name="PremiumCard" parent="Widget.Material3.CardView.Filled">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">2dp</item>
        <item name="contentPadding">24dp</item>
        <item name="cardBackgroundColor">@color/surface</item>
    </style>

    <!-- Button base - elderly friendly: larger, bolder -->
    <style name="AccesibleButton">
        <item name="android:minHeight">64dp</item>
        <item name="android:minWidth">240dp</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">16dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Emergency Button - extra large -->
    <style name="EmergencyButton">
        <item name="android:minHeight">80dp</item>
        <item name="android:backgroundTint">@color/btn_emergency</item>
        <item name="android:textColor">@color/btn_emergency_text</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.05</item>
    </style>

    <!-- Toolbar Title -->
    <style name="ToolbarTitle" parent="TextAppearance.Material3.TitleLarge">
        <item name="android:textColor">?attr/colorOnSurface</item>
    </style>

    <!-- Typography - increased sizes for elderly readability -->
    <style name="TextAppearance.HeadlineLarge" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">36sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0</item>
        <item name="android:lineSpacingExtra">6dp</item>
    </style>
    <style name="TextAppearance.HeadlineMedium" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">30sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:lineSpacingExtra">6dp</item>
    </style>
    <style name="TextAppearance.TitleMedium" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">22sp</item>
        <item name="android:fontWeight">700</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>
    <style name="TextAppearance.BodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">18sp</item>
        <item name="android:lineSpacingExtra">6dp</item>
    </style>
    <style name="TextAppearance.BodyMedium" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">16sp</item>
        <item name="android:lineSpacingExtra">4dp</item>
    </style>
    <style name="TextAppearance.LabelLarge" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontWeight">600</item>
    </style>
</resources>
