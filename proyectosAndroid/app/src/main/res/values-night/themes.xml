        <item name="colorOnPrimary">@color/on_primary</item>
        <item name="colorPrimaryContainer">#1A3A6E</item>
        <item name="colorOnPrimaryContainer">#99BBFF</item>

        <item name="colorSecondary">#4CD964</item>
        <item name="colorOnSecondary">@color/on_secondary</item>

        <item name="android:colorBackground">#0D0D12</item>
        <item name="colorSurface">#1C1C1E</item>
        <item name="colorOnSurface">#F2F2F7</item>
        <item name="colorOnSurfaceVariant">#A1A1A6</item>

        <item name="colorError">#FF453A</item>
        <item name="colorOnError">#FFFFFF</item>
